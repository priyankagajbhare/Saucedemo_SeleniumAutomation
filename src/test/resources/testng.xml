<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.1.dtd">

<suite name="SauceDemo Suite" parallel="methods" thread-count="3">

	<listeners>
		<listener
			class-name="com.automation.listners.TestListener" />
	</listeners>

	<test name="Smoke - Chrome">
		<parameter name="browser" value="chrome" />
		<groups>
			<run>
				<include name="smoke" />
			</run>
		</groups>
		<classes>
			<class name="com.automation.tests.LoginTest" />
			<class name="com.automation.tests.InventoryTest" />
			<class name="com.automation.tests.CartPageTest" />
			<class name="com.automation.tests.CheckoutStepOneTest" />
			<class name="com.automation.tests.CheckoutStepTwoTest" />
			<class name="com.automation.tests.CheckoutCompleteTest" />
		</classes>
	</test>
</suite>